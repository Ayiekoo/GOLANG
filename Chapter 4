// Exercises

// Write a program that prints out all the numbers between 1 and 100 that are evenly divisible by 3 (i.e., 3, 6, 9, etc.).


package main

import "fmt"

func main() {
    fmt.Println("Numbers between 1 and 100 evenly divisible by 3:")
    
    // Loop from 1 up to and including 100
    for i := 1; i <=100; i++ {
        // Check of the numbers are divisible by 3
        if i % 3 == 0 {
            // Print numbers divisible by 3
            fmt.Println(i)
        }
    }
}

