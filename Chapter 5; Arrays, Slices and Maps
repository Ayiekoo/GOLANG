// Let's look at a program that uses arrays to compute the average of test scores
// This program can be used in data science to compute an average. The mathematical sign / is used to find the average of the scores. We can also use other mathematical equations for other statistical functions
// This program works in 5 steps...
// step 1: Setting up an array of 5 test scores
// step 2: Creating a loop to calculate the total scores
// step 3: Diving the total scores with the number of arrays/items

package main
import "fmt"

func main() {
    var x [5]float64
    x[0] = 98
    x[1] = 93
    x[2] = 77
    x[3] = 82
    x[4] = 83
    
    var total float64 = 0
    for i := 0; i < 5; i++{
        total += x[i]
    }
  fmt.Println(total / 5)
}

// Now you can see, fmt.Println(x[4]) prints the fourth array, which is 100

// We can improve the code above, specifically the "i < 5" and "total /5"

package main
import "fmt"

func main() {
    var x [5]float64
    x[0] = 98
    x[1] = 93
    x[2] = 77
    x[3] = 82
    x[4] = 83
    
    var total float64 = 0
    for _, value := range x {
        total += value
    }
    fmt.Println(total / float64(len(x)))
}

// We introduced "len(x)" because the numbers of arrays may increase

SLICES
// Slices

// A slice is a segment of an array. They are indexable and have length

// For example "var x []float64" is a slice. The only difference between this and an array is the missing length between the brackets. In this case, the length is zero.

// To create a slice, use the built in "make" function

// see the code below

x := make([]float64, 5) // This code creates a slice associate with an underlying float64, with a length of 5.

// Slices are associated with arrays. However, the slices can never be longer than the arrays.

// The "make" function allows a third parameter; see below

x := make([]float64, 5, 10) // This shows a slice of 5 with a calacity length of 10


// ANOTHER WAY TO CREATE A SLICE
// An alternative method is using the [low : high] expression

// low is the index where the slice starts
// high is the index where the slice ends, with the exclusion of the index itself


arr := [5]float64{1,2,3,4,5}
x := arr[0:5]

// For example, while arr[0:5] returns [1,2,3,4,5], arr[1:4] returns [2,3,4].

// For convenience, we are also allowed to omit low, high, or even both low and high. See the codes below;
arr[0:] is the same as arr[0:len(arr)]

arr[:5] is the same as arr[0:5]

arr[:] is the same as arr[0:len(arr)].


// APPEND

// Append adds elements to the end of a slice

package main

import "fmt"

func main(){
    slice1 := []int{1, 2, 3}
    slice2 := append(slice1, 4, 5)
    fmt.Println(slice1, slice2)
}

// There's capacity. So, the slice was added.
// However, a new array would have been created if there was insufficient capacity

